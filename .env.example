# RePlug — Copy this file to .env and fill in your values.
# Do not commit .env to version control.

APP_ENV=local
APP_URL=http://localhost/re-plug

# Database (MySQL)
DB_HOST=localhost
DB_NAME=replug_db
DB_USER=root
DB_PASS=

