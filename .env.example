# RePlug — Copy this file to .env and fill in your values.
# Do not commit .env to version control.

APP_ENV=local
APP_URL=http://localhost/re-plug

# Database (MySQL)
DB_HOST=localhost
DB_NAME=replug_db
DB_USER=root
DB_PASS=

# Stripe Checkout
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Revenue split
DEPOT_SHARE_PERCENT=90
RECYCLER_SHARE_PERCENT=10

# Optional: for future mail or other services
# MAIL_FROM=noreply@example.com
